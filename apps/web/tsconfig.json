{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@hallederiz/ai-contracts": ["../../packages/ai-contracts/src/index.ts"],
      "@hallederiz/ai-contracts/*": ["../../packages/ai-contracts/src/*"],
      "@hallederiz/ui": ["../../packages/ui/src/index.ts"],
      "@hallederiz/ui/*": ["../../packages/ui/src/*"],
      "@hallederiz/config": ["../../packages/config/src/index.ts"],
      "@hallederiz/config/*": ["../../packages/config/src/*"],
      "@hallederiz/database": ["../../packages/database/src/index.ts"],
      "@hallederiz/database/*": ["../../packages/database/src/*"],
      "@hallederiz/types": ["../../packages/types/src/index.ts"],
      "@hallederiz/types/*": ["../../packages/types/src/*"],
      "@hallederiz/utils": ["../../packages/utils/src/index.ts"],
      "@hallederiz/utils/*": ["../../packages/utils/src/*"],
      "@hallederiz/domain": ["../../packages/domain/src/index.ts"],
      "@hallederiz/domain/*": ["../../packages/domain/src/*"],
      "@hallederiz/sdk": ["../../packages/sdk/src/index.ts"],
      "@hallederiz/sdk/*": ["../../packages/sdk/src/*"]
    },
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "noEmit": true,
    "allowJs": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".runtime-next/types/**/*.ts",
    ".runtime-next-dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
