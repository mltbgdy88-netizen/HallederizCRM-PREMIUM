NODE_ENV=development

WEB_URL=http://localhost:3000
PORT_API=4000
PORT_AI_SERVICE=4100
PORT_LOCAL_AGENT=4200
API_CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3010,http://127.0.0.1:3010

# Persistence / Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hallederizcrm
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/hallederizcrm
PERSISTENCE_MODE=demo
ALLOW_DEMO_FALLBACK=false
REDIS_URL=redis://localhost:6379

# Auth / Demo Auth
DEMO_AUTH_ENABLED=false
NEXT_PUBLIC_ENABLE_DEMO_AUTH=false
LOCAL_PILOT_AUTH_ENABLED=false
LOCAL_PILOT_AUTH_EMAIL=pilot@hallederiz.local
LOCAL_PILOT_AUTH_PASSWORD=change-me-local-only
LOCAL_PILOT_AUTH_ROLE=admin
AUTH_SEED_TENANT_SLUG=hallederiz
AUTH_SEED_TENANT_NAME=Hallederiz Operations Tenant
AUTH_SEED_ADMIN_EMAIL=admin@hallederiz.local
AUTH_SEED_ADMIN_PASSWORD=change-me-local-only
AUTH_SEED_ADMIN_FULL_NAME=Platform Admin
AUTH_SEED_ADMIN_ROLE=platform_admin

# WhatsApp
WHATSAPP_PROVIDER=mock
WHATSAPP_PROVIDER_URL=
WHATSAPP_API_BASE_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_WEBHOOK_APP_SECRET=
WHATSAPP_TEST_RECIPIENT=
WHATSAPP_TIMEOUT_MS=12000

# ERP / Factory
ERP_API_URL=
FACTORY_API_URL=

# AI
OPENAI_API_KEY=
AI_PROVIDER=local
AI_MODEL=
AI_STT_MODEL=
AI_TTS_MODEL=
AI_TTS_VOICE=
LOCAL_AI_SERVICE_URL=http://127.0.0.1:8008
LOCAL_AI_TIMEOUT_MS=30000
OLLAMA_BASE_URL=http://127.0.0.1:11434
LOCAL_AI_ALLOW_PUBLIC_URLS=false
SALES_AI_MODEL=RefinedNeuro/Turkcell-LLM-7b-v1:latest
SALES_AI_FALLBACK_MODEL=llama3.2:3b
SALES_AI_TEMPERATURE=0.2
SALES_AI_TOP_P=0.8
SALES_AI_REPEAT_PENALTY=1.15
SALES_AI_NUM_PREDICT=160

# Local Agent / Local Output
LOCAL_AGENT_MODE=disabled
LOCAL_OUTPUT_ROOT=
DEFAULT_PRINTER_NAME=
LOCAL_AGENT_POLL_INTERVAL_MS=5000
LOCAL_AGENT_HEALTH_SECRET=

TENANT_ENCRYPTION_KEY=

NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_USE_DEMO_DATA=true
NEXT_PUBLIC_TENANT_ID=tenant_1
NEXT_PUBLIC_USER_ID=user_admin

# Yerel gelistirme icin DEMO_AUTH_ENABLED ve NEXT_PUBLIC_ENABLE_DEMO_AUTH true yapilabilir.
# Local postgres dogrulamalari icin LOCAL_PILOT_AUTH_ENABLED=true yapilabilir (yalnizca development).
# LOCAL_PILOT_AUTH sadece yerel dogrulama icindir; production auth yerine gecmez.
# Gercek DB-backed auth icin admin kullanici seed scripti calistirilabilir:
# pnpm --filter @hallederiz/api seed:auth-admin
# .env.local/.env.development dosyalari commitlenmemelidir.
# ALLOW_DEMO_FALLBACK sadece development ortamina ozel gecici mock fallback icin true yapilabilir.
# Production ve postgres modunda false kalmalidir; gercek auth provider ve veritabani kullanilmalidir.
# Production notlari:
# - DEMO_AUTH_ENABLED=false ve NEXT_PUBLIC_ENABLE_DEMO_AUTH=false kalmalidir.
# - LOCAL_PILOT_AUTH_ENABLED=false kalmalidir.
# - API_CORS_ORIGINS sadece izinli web/staging originlerini icermelidir; production'da wildcard kullanilmaz.
# - PERSISTENCE_MODE=postgres kullanilirken POSTGRES_URL/DATABASE_URL zorunludur.
# - ALLOW_DEMO_FALLBACK=false kalmalidir (silent demo fallback engeli).
# - WHATSAPP_WEBHOOK_VERIFY_TOKEN ve WHATSAPP_WEBHOOK_APP_SECRET zorunludur.
# - AI_PROVIDER=local veya openai kullaniliyorsa ilgili secret/model alanlari doldurulmalidir.
# - LOCAL_AI_ALLOW_PUBLIC_URLS varsayilan false kalmalidir; true sadece bilincli ve guvenli ag tasariminda acilmalidir.
