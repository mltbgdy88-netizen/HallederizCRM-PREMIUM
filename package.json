{
  "name": "hallederizcrm-premium",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-tenant CRM and operations platform bootstrap for the wallpaper industry.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "pnpm test:api",
    "test:api": "pnpm --filter @hallederiz/api... build && node scripts/ci/ensure-workspace-entrypoints.cjs && pnpm --filter @hallederiz/api test",
    "test:web-approvals": "node scripts/run-web-approval-tests.cjs",
    "test:web-navigation": "node scripts/run-web-navigation-tests.cjs",
    "ci:local": "pnpm typecheck && pnpm build && pnpm test",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "local-ai:dev": "powershell -ExecutionPolicy Bypass -File apps/local-ai-service/start.ps1",
    "local-ai:health": "node scripts/local-ai/health.cjs",
    "smoke:routes": "node scripts/smoke/routes.cjs",
    "smoke:navigation": "node scripts/smoke/navigation.cjs",
    "smoke:production-data": "node scripts/smoke/production-data.cjs",
    "smoke:api-offline": "node scripts/smoke/api-offline.cjs",
    "smoke:all": "node scripts/smoke/all.cjs",
    "smoke:e2e": "node scripts/smoke/e2e.cjs",
    "smoke:product-readiness": "pnpm typecheck && pnpm smoke:routes && pnpm smoke:navigation",
    "smoke:production-safety": "pnpm --filter @hallederiz/api... build && pnpm --filter @hallederiz/api exec node --loader ts-node/esm --experimental-specifier-resolution=node --test src/tests/production-safety-smoke.test.ts",
    "local-ai:smoke": "node scripts/local-ai/health.cjs --degraded-ok",
    "dev:clean:windows": "powershell -ExecutionPolicy Bypass -File scripts/windows-clean-dev.ps1 -Reinstall"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "turbo": "^2.1.3",
    "typescript": "^5.6.3"
  }
}
